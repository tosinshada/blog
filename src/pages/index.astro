---
import dayjs from "dayjs";
import utc from "dayjs/plugin/utc";
import timezone from "dayjs/plugin/timezone";
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import { getPath } from "@/utils/getPath";
import { SITE } from "@/config";
import { PROJECTS } from "@/data/projects";

dayjs.extend(utc);
dayjs.extend(timezone);

const notes = await getCollection("notes");
const sortedNotes = getSortedPosts(notes);
const previewNotes = sortedNotes.slice(0, SITE.notesPerIndex);
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index">
    <section
      id="hero"
      class="mx-auto max-w-[760px] px-4 pt-16 pb-12 text-center sm:pt-24"
    >
      <h1
        class="font-serif text-4xl leading-tight font-normal text-heading sm:text-5xl md:text-[64px]"
      >
        I build things,<br />then wonder if I built<br />the right things.
      </h1>
      <p class="mt-8 text-sm font-medium text-foreground/90">Tosin Shada</p>
      <p class="text-sm text-muted-foreground">
        Software developer &middot; Lagos, Nigeria
      </p>
    </section>

    <section
      class="mx-auto max-w-app px-4 pt-2 pb-16 text-[17px] leading-relaxed text-foreground/90"
    >
      <p class="mb-5">
        I tend to overthink things &mdash; which usually means I've read the
        docs twice before writing a line of code. Most days I'm working in .NET
        and TypeScript, though I've spent enough time in Rust, Python, and Java
        to have opinions about all of them.
      </p>
      <p class="mb-5">
        Lately I'm drawn to functional languages &mdash; Haskell and Elixir
        especially &mdash; and I'm planning an Elixir project soon just to see
        how differently it makes me think.
      </p>
      <p>
        Outside of code: learning lawn tennis, and (allegedly) starting piano
        lessons soon.
      </p>
    </section>

    <section
      class="mx-auto mb-6 flex max-w-app justify-center gap-6 px-4 text-sm"
    >
      <a
        href="https://github.com/TosinShada"
        target="_blank"
        rel="noopener noreferrer"
        class="link-underline">GitHub</a
      >
      <a
        href="https://www.linkedin.com/in/shada-tosin-4b239a57/"
        target="_blank"
        rel="noopener noreferrer"
        class="link-underline">LinkedIn</a
      >
      <a
        href="https://x.com/shardoeski"
        target="_blank"
        rel="noopener noreferrer"
        class="link-underline">X</a
      >
    </section>

    <div class="mx-auto max-w-app px-4">
      <hr class="my-6 border-border" />
    </div>

    <section id="notes" class="mx-auto max-w-app px-4 pb-16">
      <h2 class="mb-6 font-serif text-2xl font-normal text-heading">Notes</h2>
      {
        previewNotes.length > 0 ? (
          <ul>
            {previewNotes.map(note => {
              const date = dayjs(note.data.pubDatetime).tz(
                note.data.timezone || SITE.timezone
              );
              return (
                <li class="border-b border-border">
                  <a
                    href={getPath(note.id, note.filePath)}
                    class="block py-5 hover:opacity-80"
                  >
                    <div class="flex items-baseline justify-between gap-4">
                      <span class="text-base text-foreground">
                        {note.data.title}
                      </span>
                      <span class="text-xs whitespace-nowrap text-muted-foreground">
                        {date.format("MMM YYYY")}
                      </span>
                    </div>
                    <p class="mt-1.5 text-sm leading-relaxed text-muted-foreground">
                      {note.data.description}
                    </p>
                  </a>
                </li>
              );
            })}
          </ul>
        ) : (
          <p class="text-sm text-muted-foreground">
            Nothing published yet &mdash; check back soon.
          </p>
        )
      }
      {
        sortedNotes.length > SITE.notesPerIndex && (
          <div class="mt-6 text-center">
            <a href="/notes" class="link-underline text-sm">
              All notes &rarr;
            </a>
          </div>
        )
      }
    </section>

    <section id="projects" class="mx-auto max-w-app px-4 pb-16">
      <h2 class="mb-6 font-serif text-2xl font-normal text-heading">
        Projects
      </h2>
      {
        PROJECTS.map(proj => (
          <a
            href={proj.href}
            target="_blank"
            rel="noopener noreferrer"
            class="mb-4 block rounded border border-border bg-card px-6 py-5 hover:border-accent/50"
          >
            <div class="mb-1.5 text-base text-foreground">{proj.name}</div>
            <p class="text-sm leading-relaxed text-muted-foreground">
              {proj.desc}
            </p>
            <span class="mt-2 inline-block text-xs text-accent">
              {proj.repo} &rarr;
            </span>
          </a>
        ))
      }
    </section>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
